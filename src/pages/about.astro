---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us — Johnny's Diner" description="Learn about Johnny's Diner — family owned and operated on Curry Ford Road since 1995. Orlando's go-to for homestyle cooking.">
  <!-- Header -->
  <section class="bg-diner-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 text-center text-white">
      <h1 class="font-display text-4xl md:text-5xl mb-2 hero-animate hero-animate-1">Our Story</h1>
      <p class="text-lg font-light hero-animate hero-animate-2">Family owned & operated &mdash; then, now, always</p>
    </div>
  </section>

  <!-- Story -->
  <section class="max-w-3xl mx-auto px-4 py-16 md:py-24">
    <div class="space-y-12">
      <!-- 1995 -->
      <div class="flex gap-6">
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-diner-red text-white flex items-center justify-center font-display text-lg shrink-0 shadow-lg ring-4 ring-diner-red/20">
            '95
          </div>
          <div class="w-0.5 bg-diner-red/30 flex-1 mt-2"></div>
        </div>
        <div class="pb-8">
          <h2 class="font-display text-2xl text-diner-dark mb-3">Where It All Started</h2>
          <p class="text-diner-gray leading-relaxed mb-6">
            Johnny's Diner first opened its doors in 1995, born from the dream of Giovanni (Johnny) Krasniqi.
            With a deep passion for classic American homestyle cooking and a desire to create a welcoming space
            for the community, he established a diner that quickly became a local favorite on Curry Ford Road
            in Orlando. From day one, the mission was simple: serve honest food with a smile and a bottomless
            cup of coffee.
          </p>
          <div class="menu-card overflow-hidden">
            <img src="/johnny-founder.jpg" alt="Johnny Krasniqi — founder of Johnny's Diner, 1995" class="w-full h-auto" />
            <p class="text-center text-sm text-diner-gray py-3">Johnny Krasniqi &mdash; Founder, 1999</p>
          </div>
        </div>
      </div>

      <!-- Growth -->
      <div class="flex gap-6">
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-diner-red text-white flex items-center justify-center shrink-0 shadow-lg ring-4 ring-diner-red/20">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
            </svg>
          </div>
          <div class="w-0.5 bg-diner-red/30 flex-1 mt-2"></div>
        </div>
        <div class="pb-8">
          <h2 class="font-display text-2xl text-diner-dark mb-3">Growing With the Neighborhood</h2>
          <p class="text-diner-gray leading-relaxed">
            What started as breakfast-only expanded into a full menu of comfort classics &mdash;
            burgers, sandwiches, dinners, and all the southern favorites that keep people coming back.
            The griddle never stopped, and neither did the community's love.
          </p>
        </div>
      </div>

      <!-- Today -->
      <div class="flex gap-6">
        <div class="flex flex-col items-center">
          <div class="w-14 h-14 rounded-full bg-diner-red text-white flex items-center justify-center font-display text-base shrink-0 shadow-lg ring-4 ring-diner-red/20">
            Now
          </div>
        </div>
        <div>
          <h2 class="font-display text-2xl text-diner-dark mb-3">The Curry Ford Family</h2>
          <p class="text-diner-gray leading-relaxed mb-6">
            Today, the Curry Ford Road location is owned and operated by family &mdash; the way it was always meant to be.
            Cousins Martin and Marian carry on the tradition Johnny built, with Pal, Johnny's son, part of the family
            that has kept these doors open and this community fed for over 30 years.
          </p>
          <div class="menu-card overflow-hidden">
            <img src="/owners-trio.jpg" alt="Martin, Pal, and Marian — owners of Johnny's Diner Curry Ford" class="w-full h-80 object-cover object-top" />
            <p class="text-center text-sm text-diner-gray py-3">Martin, Pal & Marian &mdash; Owners, Curry Ford Location</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social -->
  <section class="bg-diner-dark relative overflow-hidden py-14">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display text-white text-3xl mb-3">Follow Along</h2>
      <p class="text-white/60 mb-8">See what's cooking — follow us on social media for daily specials, behind-the-scenes, and more.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="https://www.facebook.com/profile.php?id=61576530234741" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#1877F2] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition-opacity">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
        <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-gradient-to-r from-[#f09433] via-[#e6683c] to-[#bc1888] text-white font-semibold px-6 py-3 rounded-full hover:opacity-90 transition-opacity">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display text-diner-red text-3xl text-center mb-10">Awards & Recognition</h2>

      <!-- 2026 Featured Awards -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="menu-card overflow-hidden">
          <img
            src="/award-2026-best-breakfast.jpg"
            alt="Orlando Sentinel Foodie Awards 2026 — Readers Choice Winner: Best Breakfast"
            class="w-full h-56 object-cover"
          />
          <div class="p-6 text-center">
            <div class="inline-block bg-diner-red text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3">2026 Win</div>
            <h3 class="font-display text-diner-dark text-xl mb-1">Orlando Sentinel Foodie Awards</h3>
            <p class="text-diner-red font-semibold">Readers Choice &mdash; Best Breakfast</p>
          </div>
        </div>
        <div class="menu-card overflow-hidden">
          <img
            src="/award-2026-best-diner.jpg"
            alt="Orlando Sentinel Foodie Awards 2026 — Readers Choice Winner: Best Diner"
            class="w-full h-56 object-cover"
          />
          <div class="p-6 text-center">
            <div class="inline-block bg-diner-red text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3">2026 Win</div>
            <h3 class="font-display text-diner-dark text-xl mb-1">Orlando Sentinel Foodie Awards</h3>
            <p class="text-diner-red font-semibold">Readers Choice &mdash; Best Diner</p>
          </div>
        </div>
      </div>

      <!-- Other Awards Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="menu-card p-5 text-center">
          <div class="font-bold text-diner-red text-2xl">2024</div>
          <p class="text-xs text-diner-gray mt-2">Orlando Weekly Finalist &mdash; Best East Orlando Restaurant</p>
        </div>
        <div class="menu-card p-5 text-center">
          <div class="font-bold text-diner-red text-2xl">2023</div>
          <p class="text-xs text-diner-gray mt-2">Orlando Sentinel Winner &mdash; Best Breakfast in Orlando</p>
        </div>
        <div class="menu-card p-5 text-center">
          <div class="font-bold text-diner-red text-2xl">2021</div>
          <p class="text-xs text-diner-gray mt-2">OpenTable Nominee &mdash; Top Local Diner</p>
        </div>
        <div class="menu-card p-5 text-center">
          <div class="font-bold text-diner-red text-2xl">2020</div>
          <p class="text-xs text-diner-gray mt-2">Yelp Honorable Mention &mdash; Reader's Choice</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h2 class="font-display text-diner-red text-3xl text-center mb-10">What We Stand For</h2>
    <div class="grid md:grid-cols-3 gap-6 mb-10">
      <div class="menu-card p-6 text-center">
        <h3 class="font-semibold text-diner-dark mb-2">Fresh Daily</h3>
        <p class="text-sm text-diner-gray">Quality, locally sourced ingredients prepared from scratch every morning.</p>
      </div>
      <div class="menu-card p-6 text-center">
        <h3 class="font-semibold text-diner-dark mb-2">Community First</h3>
        <p class="text-sm text-diner-gray">Proud member of Curry Ford West. We partner with area farms and bakeries.</p>
      </div>
      <div class="menu-card p-6 text-center">
        <h3 class="font-semibold text-diner-dark mb-2">Always Family</h3>
        <p class="text-sm text-diner-gray">You're family the moment you walk in. That's been true since 1995.</p>
      </div>
    </div>
    <div class="menu-card overflow-hidden">
      <img src="/diner-night.jpg" alt="Supporting Our Schools — Diner Night" class="w-full h-72 object-cover object-top" />
      <div class="p-6 text-center">
        <h3 class="font-semibold text-diner-dark text-lg mb-2">Supporting Our Schools</h3>
        <p class="text-sm text-diner-gray">We partner with nearby schools for "Diner Nights," where a portion of our proceeds goes directly to supporting educational programs and events.</p>
      </div>
    </div>
  </section>
</Layout>
