    <div class="max-w-3xl mx-auto">
      <div class="relative bg-diner-red-light rounded-[20px] border-4 border-diner-red overflow-hidden px-8 py-14 text-center">
        <div class="absolute inset-0 stripe-bg-light"></div>
        <div class="relative">
          <h2 class="font-display text-diner-red text-4xl md:text-5xl leading-tight mb-4">Proud Member of the<br/>Curry Ford West Community</h2>
          <p class="text-diner-gray max-w-xl mx-auto mb-8">Johnny's Diner is honored to support our Curry Ford West neighbors, businesses, and community events.</p>
          <div class="flex justify-center mb-8">
            <div class="bg-white rounded-2xl p-4 shadow-md">
              <img src="/curryfordwest-logo.png" alt="Curry Ford West" class="h-36 w-auto" />
            </div>
          </div>
          <a href="https://curryfordwest.com" target="_blank" rel="noopener noreferrer" class="inline-block bg-diner-red text-white font-bold px-8 py-3 rounded-full hover:bg-diner-red-dark transition-colors mb-4">
            Learn About Curry Ford West
          </a>
          <p class="text-diner-gray text-sm">We love our neighborhood — thanks for letting us be part of it!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section id="awards" class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-display text-diner-red text-3xl text-center mb-10">Awards & Recognition</h2>

      <!-- 2026 Featured Awards -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
