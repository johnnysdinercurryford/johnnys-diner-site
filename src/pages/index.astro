---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Johnny's Diner — Best Breakfast in Orlando Since 1995">
  <!-- Hero -->
  <section class="relative bg-diner-red overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 md:py-24 flex justify-center">
      <div class="relative bg-white rounded-[22px] border-[3px] border-diner-red text-center w-full max-w-xl hero-animate hero-animate-1" style="box-shadow: 0 10px 25px rgba(0,0,0,0.28); padding: 40px;">
        <!-- 31 Years Badge -->
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 flex items-center gap-2 bg-diner-dark border border-white/20 px-5 py-1.5 rounded-full shadow-lg">
          <span class="font-black text-[#F5C800] text-xl leading-none">31</span>
          <div class="w-px h-4 bg-white/30"></div>
          <span class="font-bold text-white text-xs uppercase tracking-widest">Years In Business</span>
        </div>
        <img src="/logo.png" alt="Johnny's Diner" class="h-72 md:h-96 w-auto mx-auto mb-4" />
        <p class="text-diner-gray text-lg mb-8">Family owned & operated &mdash; Homestyle cooking since '95</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/menu" class="inline-block bg-diner-red text-white font-semibold px-8 py-3 rounded-full hover:bg-diner-red-dark transition-colors active:scale-95">
            View Our Menu
          </a>
          <a href="tel:+14078688267" class="inline-block bg-diner-red text-white font-semibold px-8 py-3 rounded-full hover:bg-diner-red-dark transition-colors active:scale-95">
            Call Us
          </a>
        </div>
        <!-- Social links -->
        <div class="flex items-center justify-center gap-3 mt-6 pt-6 border-t border-diner-border">
          <a href="https://www.facebook.com/profile.php?id=61576530234741" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-11 h-11 rounded-full border-2 border-diner-border flex items-center justify-center text-[#1877F2] hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] transition-all duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-11 h-11 rounded-full border-2 border-diner-border flex items-center justify-center text-[#E1306C] hover:bg-gradient-to-br hover:from-[#f09433] hover:via-[#e6683c] hover:via-[#dc2743] hover:via-[#cc2366] hover:to-[#bc1888] hover:text-white hover:border-transparent transition-all duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" aria-label="DoorDash" class="w-11 h-11 rounded-full border-2 border-diner-border flex items-center justify-center text-[#FF3008] hover:bg-[#FF3008] hover:text-white hover:border-[#FF3008] transition-all duration-200">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm2.057 15.6H7.714V8.4h6.343c1.986 0 3.6 1.614 3.6 3.6s-1.614 3.6-3.6 3.6z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="max-w-6xl mx-auto px-4 -mt-8 relative z-10">
    <div class="menu-card p-12 md:p-16 max-w-2xl mx-auto text-center reveal">
      <h2 class="font-display text-diner-red text-4xl md:text-5xl mb-6">Hours</h2>
      <div class="text-xl md:text-2xl font-bold space-y-3">
        <p><span class="text-diner-dark">Monday &ndash; Saturday:</span> <span class="text-diner-red">6:00 AM &ndash; 3:00 PM</span></p>
        <p><span class="text-diner-dark">Sunday:</span> <span class="text-diner-red">7:00 AM &ndash; 3:00 PM</span></p>
        <p class="text-diner-gray text-sm font-normal mt-4">Holiday hours may vary. Please call ahead.</p>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="bg-diner-red relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <h2 class="font-display text-white text-3xl md:text-4xl text-center mb-2 reveal">Awards & Recognition</h2>
      <p class="text-center text-white/70 mb-12 reveal">Orlando Sentinel Foodie Awards &mdash; Readers Choice 2026</p>
      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <div class="slide-left text-center">
          <div class="menu-card overflow-hidden mb-4">
            <img src="/award-best-diner.jpg" alt="Orlando Sentinel Foodie Awards — Readers Choice Best Diner 2026" class="w-full h-auto" />
          </div>
          <p class="text-white font-semibold">Readers Choice &mdash; Best Diner</p>
          <p class="text-white/70 text-sm mt-1">Orlando Sentinel Foodie Awards 2026</p>
        </div>
        <div class="slide-right text-center">
          <div class="menu-card overflow-hidden mb-4">
            <img src="/award-best-breakfast.jpg" alt="Orlando Sentinel Foodie Awards — Readers Choice Best Breakfast 2026" class="w-full h-auto" />
          </div>
          <p class="text-white font-semibold">Readers Choice &mdash; Best Breakfast</p>
          <p class="text-white/70 text-sm mt-1">Orlando Sentinel Foodie Awards 2026</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <section class="bg-diner-dark py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <h2 class="font-display text-white text-3xl md:text-4xl text-center mb-10 reveal">Come Hungry. Leave Happy.</h2>
      <div class="relative">
        <div id="carousel" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4" style="scrollbar-width: none;">
          {[
            '/photos/IMG_1787.jpg',
            '/photos/IMG_1788.jpg',
            '/photos/IMG_1836.jpg',
            '/photos/IMG_1841_cleaned.jpg',
            '/photos/IMG_1851_cleaned.jpg',
            '/photos/IMG_1863.jpg',
            '/photos/IMG_1864.jpg',
            '/photos/IMG_1867.jpg',
            '/photos/IMG_1877.jpg',
            '/photos/IMG_1882.jpg',
            '/photos/IMG_1903.jpg',
            '/photos/IMG_1905.jpg',
            '/photos/IMG_1920.jpg',
            '/photos/IMG_1921.jpg',
            '/photos/IMG_1925.jpg',
            '/photos/IMG_1970.jpg',
            '/photos/IMG_1976.jpg',
            '/photos/IMG_1995_cleaned.jpg',
            '/photos/IMG_2031.jpg',
          ].map((src) => (
            <div class="snap-center shrink-0 w-72 md:w-96 h-64 md:h-80 rounded-2xl overflow-hidden">
              <img src={src} alt="Johnny's Diner" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
          ))}
        </div>
        <!-- Prev/Next buttons -->
        <button id="carousel-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 bg-white text-diner-red w-10 h-10 rounded-full shadow-lg flex items-center justify-center hover:bg-diner-cream transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="carousel-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 bg-white text-diner-red w-10 h-10 rounded-full shadow-lg flex items-center justify-center hover:bg-diner-cream transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Instagram Feed -->
  <section class="bg-diner-dark relative overflow-hidden py-16 md:py-20">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-5xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <!-- Left: CTA -->
        <div class="flex-1 text-center md:text-left reveal">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </div>
          <h2 class="font-display text-white text-3xl md:text-4xl mb-3">We're on Instagram</h2>
          <p class="text-white/60 mb-2 text-lg">@johnnysdinercurryford</p>
          <p class="text-white/50 text-sm mb-8 leading-relaxed">Follow along for daily specials, behind-the-scenes, and a peek at what's cooking on the flat-top.</p>
          <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full transition-all duration-200" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            Follow Us
          </a>
        </div>
        <!-- Right: widget in a rounded card -->
        <div class="shrink-0 reveal">
          <div class="rounded-2xl overflow-hidden shadow-2xl" style="width:300px; height:300px;">
            <script src="https://snapwidget.com/js/snapwidget.js"></script>
            <iframe src="https://snapwidget.com/embed/1120590" class="snapwidget-widget" allowtransparency="true" frameborder="0" scrolling="no" style="border:none; overflow:hidden; width:300px; height:300px;" title="Posts from Instagram"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Snippet -->
  <section class="bg-diner-red-light relative overflow-hidden max-w-full px-4 py-16 md:py-24">
  <div class="absolute inset-0 stripe-bg-light"></div>
  <div class="relative max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="slide-left">
        <h2 class="font-display text-diner-red text-3xl md:text-4xl mb-4">Since 1995</h2>
        <p class="text-diner-gray leading-relaxed mb-4">
          What started as a humble 8-booth diner on Curry Ford Road has grown alongside the neighborhood
          into Orlando's go-to spot for homestyle cookin'. We serve it hot off the flat-top,
          with friendly faces and a fresh pot of coffee.
        </p>
        <p class="text-diner-gray leading-relaxed mb-6">
          From fluffy buttermilk pancakes to hand-formed burgers and stacked sandwiches &mdash;
          you're family the moment you walk in.
        </p>
        <a href="/about" class="text-diner-red font-semibold hover:text-diner-red-dark transition-colors">
          Read Our Story &rarr;
        </a>
      </div>
      <div class="menu-card p-8 text-center slide-right">
        <div class="font-display text-6xl text-diner-red mb-2">31</div>
        <p class="text-diner-gray">Years Serving Orlando</p>
      </div>
    </div>
  </div>
  </section>

  <!-- Highlights -->
  <section class="bg-diner-yellow relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 stripe-bg-light"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <h2 class="font-display text-diner-red text-3xl md:text-4xl text-center mb-12 reveal">Why Orlando Loves Us</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="menu-card p-6 text-center reveal">
          <div class="w-16 h-16 bg-diner-red-tint rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-diner-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-diner-dark mb-2">All-Day Breakfast</h3>
          <p class="text-sm text-diner-gray">Pancakes, omelettes, biscuits & gravy &mdash; served from open to close. No rush.</p>
        </div>
        <div class="menu-card p-6 text-center reveal">
          <div class="w-16 h-16 bg-diner-yellow rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-diner-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-diner-dark mb-2">Bottomless Coffee</h3>
          <p class="text-sm text-diner-gray">Your cup never goes empty. We'll keep you topped off while you enjoy your meal.</p>
        </div>
        <div class="menu-card p-6 text-center reveal">
          <div class="w-16 h-16 bg-diner-red-tint rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-diner-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="font-display text-xl text-diner-dark mb-2">Community First</h3>
          <p class="text-sm text-diner-gray">Proud member of the Curry Ford West community. We partner with local farms and bakeries.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Delivery -->
  <section class="bg-diner-dark relative overflow-hidden py-16 md:py-20">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 text-center reveal">
      <h2 class="font-display text-white text-3xl md:text-4xl mb-3">Order Delivery</h2>
      <p class="text-white/60 mb-10">Can't make it in? We've got you covered.</p>
      <a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-4 bg-[#FF3008] hover:bg-[#e02a07] transition-colors text-white font-bold text-xl px-10 py-5 rounded-full">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm2.057 15.6H7.714V8.4h6.343c1.986 0 3.6 1.614 3.6 3.6s-1.614 3.6-3.6 3.6z"/>
        </svg>
        Order on DoorDash
      </a>
    </div>
  </section>

  <!-- Location -->
  <section class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    <div class="menu-card overflow-hidden reveal">
      <div class="grid md:grid-cols-2">
        <div class="p-8 md:p-12 slide-left">
          <h2 class="font-display text-diner-red text-3xl mb-4">Find Us</h2>
          <address class="not-italic text-diner-gray leading-relaxed">
            <p class="font-semibold text-diner-dark mb-2">Johnny's Diner</p>
            <p>3335 Curry Ford Rd<br/>Orlando, FL 32806</p>
            <p class="mt-3">
              <a href="tel:+14078688267" class="text-diner-red hover:text-diner-red-dark transition-colors">(407) 868-8267</a>
            </p>
          </address>
          <div class="mt-6">
            <a href="https://maps.google.com/?q=3335+Curry+Ford+Rd+Orlando+FL+32806" target="_blank" rel="noopener" class="inline-block bg-diner-red text-white font-semibold px-6 py-2.5 rounded-full text-sm hover:bg-diner-red-dark transition-colors">
              Get Directions
            </a>
          </div>
        </div>
