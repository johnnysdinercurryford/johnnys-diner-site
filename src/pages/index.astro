---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Johnny's Diner — Best Breakfast in Orlando Since 1995">
  <!-- Hero -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">
    <img
      src="/diner-exterior.jpg"
      alt="Johnny's Diner — 3335 Curry Ford Rd, Orlando"
      class="absolute inset-0 w-full h-full object-cover object-center hero-zoom"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/5"></div>
    <!-- Years badge — top right -->
    <div class="hero-slide-right absolute top-6 right-6 hidden md:flex flex-col items-center justify-center z-10">
      <div class="bg-black/60 border border-white/20 backdrop-blur-sm rounded-2xl px-6 py-5 text-center">
        <span class="font-black text-[#F5C800] text-5xl leading-none block">31</span>
        <div class="w-8 h-px bg-white/30 mx-auto my-2"></div>
        <span class="font-bold text-white text-xs uppercase tracking-widest block">Years In Business</span>
      </div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-14 md:py-32 w-full">
      <div class="max-w-xl flex flex-col items-center text-center md:items-start md:text-left">
        <div class="hero-animate hero-animate-2 mb-5">
          <div class="logo-card inline-block bg-white stripe-bg-light rounded-2xl px-5 py-3 shadow-xl">
            <img src="/logo.png" alt="Johnny's Diner" class="w-48 md:w-72 h-auto" />
          </div>
        </div>
        <p class="hero-animate hero-animate-3 hero-text-white text-white font-bold text-3xl md:text-5xl mb-2 tracking-widest uppercase">Breakfast, Lunch &amp; Dinner</p>
        <p class="hero-animate hero-animate-3 hero-text-red text-diner-red font-bold text-xl md:text-3xl mb-2 tracking-wide">Curry Ford Road &mdash; Orlando, FL</p>
        <p class="hero-animate hero-animate-3 hero-text-white text-white font-bold text-2xl md:text-4xl mb-6 leading-snug tracking-wide">Family Owned &amp; Operated<br/>Homestyle Cooking Since 1995</p>
        <div class="hero-animate hero-animate-4 flex flex-col sm:flex-row gap-3 mb-8">
          <a href="/menu" class="inline-block bg-diner-red text-white font-semibold px-8 py-3 rounded-full transition-all duration-200 hover:scale-110 hover:bg-white hover:text-diner-red active:scale-95 shadow-md text-center">
            View Our Menu
          </a>
          <a href="tel:+14078688267" class="inline-block bg-white text-diner-dark font-semibold px-8 py-3 rounded-full transition-all duration-200 hover:scale-110 hover:bg-diner-red hover:text-white active:scale-95 text-center shadow-md">
            📞 Call Us
          </a>
        </div>
        <!-- Google rating -->
        <a href="https://www.google.com/search?q=Johnny%27s+Diner+Curry+Ford+Orlando+reviews" target="_blank" rel="noopener noreferrer" class="hero-animate hero-animate-5 inline-flex items-center gap-2 mb-5 bg-white/10 backdrop-blur-sm border border-white/20 px-4 py-2 rounded-full text-white text-sm hover:bg-white/20 transition-colors">
          <span class="text-[#FBBC04] tracking-tight text-base">★★★★★</span>
          <span class="font-medium">Highly Rated on Google</span>
          <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
        <!-- Social links -->
        <div class="hero-animate hero-animate-5 flex items-center gap-4">
          <a href="https://www.facebook.com/profile.php?id=61576530234741" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-11 h-11 rounded-full flex items-center justify-center text-white bg-[#1877F2] hover:opacity-80 transition-opacity">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-11 h-11 rounded-full flex items-center justify-center text-white hover:opacity-80 transition-opacity" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
          </a>
          <a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" aria-label="DoorDash" class="w-11 h-11 rounded-full flex items-center justify-center text-white bg-[#FF3008] hover:opacity-80 transition-opacity">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm2.057 15.6H7.714V8.4h6.343c1.986 0 3.6 1.614 3.6 3.6s-1.614 3.6-3.6 3.6z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="max-w-6xl mx-auto px-4 py-12 relative z-10">
    <div class="menu-card p-12 md:p-16 max-w-2xl mx-auto text-center reveal">
      <h2 class="font-display text-diner-red text-4xl md:text-5xl mb-6">Hours</h2>
      <div class="text-xl md:text-2xl font-bold space-y-3">
        <p><span class="text-diner-dark">Monday &ndash; Saturday:</span> <span class="text-diner-red">6:00 AM &ndash; 3:00 PM</span></p>
        <p><span class="text-diner-dark">Sunday:</span> <span class="text-diner-red">7:00 AM &ndash; 3:00 PM</span></p>
        <p class="text-diner-gray text-sm font-normal mt-4">Holiday hours may vary. Please call ahead.</p>
        <div class="border-t border-diner-border mt-6 pt-6">
          <p class="text-diner-dark font-semibold text-base">3335 Curry Ford Rd, Orlando, FL 32806</p>
          <a href="https://maps.google.com/?q=3335+Curry+Ford+Rd+Orlando+FL+32806" target="_blank" rel="noopener" class="text-diner-red text-sm font-medium hover:text-diner-red-dark transition-colors">Get Directions &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="bg-diner-red relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <h2 class="font-display text-white text-3xl md:text-4xl text-center mb-2 reveal">Awards & Recognition</h2>
      <p class="text-center text-white/70 mb-12 reveal">Orlando Sentinel Foodie Awards &mdash; Readers Choice 2026</p>
      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <div class="slide-left text-center">
          <div class="menu-card overflow-hidden mb-4">
            <img src="/award-best-diner.jpg" alt="Orlando Sentinel Foodie Awards — Readers Choice Best Diner 2026" class="w-full h-auto" />
          </div>
          <p class="text-white font-semibold">Readers Choice &mdash; Best Diner</p>
          <p class="text-white/70 text-sm mt-1">Orlando Sentinel Foodie Awards 2026</p>
        </div>
        <div class="slide-right text-center">
          <div class="menu-card overflow-hidden mb-4">
            <img src="/award-best-breakfast.jpg" alt="Orlando Sentinel Foodie Awards — Readers Choice Best Breakfast 2026" class="w-full h-auto" />
          </div>
          <p class="text-white font-semibold">Readers Choice &mdash; Best Breakfast</p>
          <p class="text-white/70 text-sm mt-1">Orlando Sentinel Foodie Awards 2026</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull Quotes -->
  <section class="coffee-bg py-14 md:py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-6 items-center">
        <div class="menu-card p-8 reveal">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-diner-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-diner-gray leading-relaxed italic mb-4">"Looking for a deliciously solid diner that won't disappoint? This is the spot. Great food, great portions (not too big, not too little). Food is fresh, not greasy, and you don't feel that groggy feeling after eating. Also, best corned beef hash in town!"</p>
          <p class="text-diner-dark font-semibold text-sm">— Jennifer Arboleda &nbsp;<span class="text-diner-gray font-normal">Google Review</span></p>
        </div>
        <!-- Mug -->
        <div class="flex justify-center reveal">
          <img src="/mug.png" alt="Johnny's Diner Curry Ford mug" class="w-56 md:w-64 h-auto drop-shadow-xl" />
        </div>
        <div class="menu-card p-8 reveal">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-diner-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-diner-gray leading-relaxed italic mb-4">"Johnnys diner is a great addition to Curryford. The service is great and the food is amazing. I eat here a couple times a week and the service and food keep me coming back."</p>
          <p class="text-diner-dark font-semibold text-sm">— Lane Backwell &nbsp;<span class="text-diner-gray font-normal">Google Review</span></p>
        </div>
      </div>
    </div>
  </section>

  <div class="stripe-divider"></div>

  <!-- Stats -->
  <section class="bg-white py-14">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-3 gap-4 md:gap-6 mb-4">
        <div class="menu-card p-6 md:p-10 text-center reveal">
          <div class="font-display text-diner-red text-4xl md:text-6xl mb-3">31</div>
          <p class="text-diner-gray text-sm md:text-base">Years Serving Orlando</p>
        </div>
        <div class="menu-card p-6 md:p-10 text-center reveal">
          <div class="font-display text-diner-red text-4xl md:text-6xl mb-3">216K</div>
          <p class="text-diner-gray text-sm md:text-base">Pancakes Flipped*</p>
        </div>
        <div class="menu-card p-6 md:p-10 text-center reveal">
          <div class="font-display text-diner-red text-4xl md:text-6xl mb-3">876K</div>
          <p class="text-diner-gray text-sm md:text-base">Coffee Refill Smiles*</p>
        </div>
      </div>
      <p class="text-xs text-diner-gray text-center">*Estimated — our grill team's too busy to count.</p>
    </div>
  </section>

  <!-- Photo Carousel -->
  <section class="bg-diner-dark py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <h2 class="font-display text-white text-3xl md:text-4xl text-center mb-10 reveal">Come Hungry. Leave Happy.</h2>
      <div class="relative">
        <div id="carousel" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4" style="scrollbar-width: none;">
          {[
            '/photos/IMG_1787.jpg',
            '/photos/IMG_1788.jpg',
            '/photos/IMG_1836.jpg',
            '/photos/IMG_1841_cleaned.jpg',
            '/photos/IMG_1851_cleaned.jpg',
            '/photos/IMG_1863.jpg',
            '/photos/IMG_1864.jpg',
            '/photos/IMG_1867.jpg',
            '/photos/IMG_1877.jpg',
            '/photos/IMG_1882.jpg',
            '/photos/IMG_1903.jpg',
            '/photos/IMG_1905.jpg',
            '/photos/IMG_1920.jpg',
            '/photos/IMG_1921.jpg',
            '/photos/IMG_1925.jpg',
            '/photos/IMG_1970.jpg',
            '/photos/IMG_1976.jpg',
            '/photos/IMG_1995_cleaned.jpg',
            '/photos/IMG_2031.jpg',
          ].map((src) => (
            <div class="snap-center shrink-0 w-72 md:w-96 h-64 md:h-80 rounded-2xl overflow-hidden">
              <img src={src} alt="Johnny's Diner" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
          ))}
        </div>
        <!-- Prev/Next buttons -->
        <button id="carousel-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 bg-white text-diner-red w-10 h-10 rounded-full shadow-lg flex items-center justify-center hover:bg-diner-cream transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="carousel-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 bg-white text-diner-red w-10 h-10 rounded-full shadow-lg flex items-center justify-center hover:bg-diner-cream transition-colors z-10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Instagram Feed -->
  <section class="bg-diner-cream relative overflow-hidden py-16 md:py-20">
    <div class="absolute inset-0 stripe-bg-light"></div>
    <div class="relative max-w-5xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <!-- Left: CTA -->
        <div class="flex-1 text-center md:text-left reveal">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
          </div>
          <h2 class="font-display text-diner-dark text-3xl md:text-4xl mb-3">We're on Instagram</h2>
          <p class="text-diner-gray mb-2 text-lg">@johnnysdinercurryford</p>
          <p class="text-diner-gray text-sm mb-8 leading-relaxed">Follow along for daily specials, behind-the-scenes, and a peek at what's cooking on the flat-top.</p>
          <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full transition-all duration-200" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
            Follow Us
          </a>
        </div>
        <!-- Right: widget in a rounded card -->
        <div class="shrink-0 reveal">
          <div class="rounded-2xl overflow-hidden shadow-2xl" style="width:240px;">
            <script src="https://snapwidget.com/js/snapwidget.js"></script>
            <iframe src="https://snapwidget.com/embed/1120590" class="snapwidget-widget" allowtransparency="true" frameborder="0" scrolling="no" style="border:none; overflow:hidden; width:240px; height:240px;" title="Posts from Instagram"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Snippet -->
  <section class="bg-white relative overflow-hidden py-16 md:py-24">
    <div class="relative max-w-3xl mx-auto px-4 text-center">
      <p class="text-diner-red font-semibold text-sm uppercase tracking-widest mb-3 reveal">Curry Ford Road, Orlando</p>
      <h2 class="font-display text-diner-dark text-4xl md:text-5xl mb-6 reveal">A Neighborhood Diner<br/>Done Right</h2>
      <p class="text-diner-gray leading-relaxed text-lg mb-10 reveal">
        What started as a humble 8-booth spot on Curry Ford Road has grown into Orlando's go-to for homestyle cookin'. Hot off the flat-top, friendly faces, and a fresh pot of coffee waiting for you every morning.
      </p>
      <!-- Stats row -->
      <div class="flex flex-wrap justify-center gap-4 mb-10 reveal">
        <div class="bg-diner-red-light border border-diner-border rounded-2xl px-8 py-5 text-center">
          <div class="font-display text-4xl text-diner-red leading-none mb-1">31</div>
          <div class="text-diner-gray text-xs uppercase tracking-widest font-semibold">Years Open</div>
        </div>
