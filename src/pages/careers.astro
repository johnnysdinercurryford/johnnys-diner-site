---
import Layout from '../layouts/Layout.astro';

const positions = {
  "Front of House": [
    { title: "Server", desc: "Handle table service, orders, and food delivery. POS experience preferred." },
    { title: "Host", desc: "Greet guests, manage waitlists, and seat diners efficiently." },
    { title: "Busser", desc: "Reset tables, support service staff, and maintain cleanliness." },
  ],
  "Back of House": [
    { title: "Line Cook", desc: "Prepare diner classics on flat-top and grill with consistency." },
    { title: "Prep Cook", desc: "Chop, portion, and prepare sauces, batters, and proteins following food safety standards." },
    { title: "Grill Cook", desc: "Operate grill station for burgers and manage ticket timing." },
    { title: "Dishwasher", desc: "Maintain dishes, cookware, and assist with kitchen tasks." },
  ],
};

const allPositions = [
  "Server (FOH)", "Host (FOH)", "Busser (FOH)",
  "Dishwasher (BOH)", "Prep Cook (BOH)", "Line Cook (BOH)", "Grill Cook (BOH)",
];

const states = [
  "AL","AK","AZ","AR","CA","CO","CT","DE","FL","GA","HI","ID","IL","IN","IA","KS",
  "KY","LA","ME","MD","MA","MI","MN","MS","MO","MT","NE","NV","NH","NJ","NM","NY",
  "NC","ND","OH","OK","OR","PA","RI","SC","SD","TN","TX","UT","VT","VA","WA","WV","WI","WY","DC",
];

const educationLevels = [
  "Some High School",
  "High School Diploma/GED",
  "Some College/Technical Training",
  "College Degree",
  "Graduate/Professional Degree",
];

const days = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"];
---

<Layout title="Careers — Johnny's Diner" description="Join the Johnny's Diner family. View open positions and apply today. Front of house and back of house roles available.">
  <!-- Header -->
  <section class="bg-diner-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.3) 10px, rgba(255,255,255,0.3) 20px);"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 text-center text-white">
      <h1 class="font-display text-4xl md:text-5xl mb-2">Join Our Family</h1>
      <p class="text-lg font-light">More than a place to eat &mdash; it's a place to belong</p>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="font-display text-diner-red text-3xl text-center mb-10">Open Positions</h2>

    {Object.entries(positions).map(([category, roles]) => (
      <div class="mb-10">
        <h3 class="font-semibold text-lg text-diner-dark mb-4 border-b border-diner-border pb-2">{category}</h3>
        <div class="grid gap-3">
          {roles.map((role) => (
            <div class="bg-white rounded-xl p-5 shadow-sm flex justify-between items-start gap-4">
              <div>
                <h4 class="font-semibold text-diner-dark">{role.title}</h4>
                <p class="text-sm text-diner-gray mt-1">{role.desc}</p>
              </div>
              <a href="#application" class="shrink-0 text-sm font-medium text-diner-red hover:text-diner-red-dark transition-colors">
                Apply &darr;
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- Application Form -->
  <section id="application" class="bg-white py-16 scroll-mt-20">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display text-diner-red text-3xl text-center mb-2">Apply Now</h2>
      <p class="text-center text-diner-gray mb-10">Fill out the form below and we'll be in touch.</p>

      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" enctype="multipart/form-data" class="space-y-8">

        <!-- Personal Info -->
        <fieldset>
          <legend class="font-semibold text-diner-dark text-lg mb-4">Personal Information</legend>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-medium text-diner-dark mb-1">First Name *</label>
              <input type="text" id="first-name" name="first_name" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-diner-dark mb-1">Last Name *</label>
              <input type="text" id="last-name" name="last_name" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-4 mt-4">
            <div>
              <label for="email" class="block text-sm font-medium text-diner-dark mb-1">Email *</label>
              <input type="email" id="email" name="email" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-diner-dark mb-1">Phone *</label>
              <input type="tel" id="phone" name="phone" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          </div>
          <div class="mt-4">
            <label for="dob" class="block text-sm font-medium text-diner-dark mb-1">Date of Birth *</label>
            <input type="date" id="dob" name="date_of_birth" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
          </div>
          <div class="mt-4 space-y-3">
            <label class="block text-sm font-medium text-diner-dark">Address *</label>
            <input type="text" name="address_line1" placeholder="Address Line 1" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            <input type="text" name="address_line2" placeholder="Address Line 2" class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            <div class="grid grid-cols-5 gap-3">
              <input type="text" name="city" placeholder="City" required class="col-span-2 rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
              <select name="state" required class="col-span-1 rounded-lg border border-diner-border px-2 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red">
                <option value="">State</option>
                {states.map((s) => <option value={s}>{s}</option>)}
              </select>
              <input type="text" name="zip" placeholder="Zip" required class="col-span-2 rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          </div>
        </fieldset>

        <!-- Position & Availability -->
        <fieldset>
          <legend class="font-semibold text-diner-dark text-lg mb-4">Position & Availability</legend>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label for="position" class="block text-sm font-medium text-diner-dark mb-1">Position Applying For *</label>
              <select id="position" name="position" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red">
                <option value="">Select a position</option>
                {allPositions.map((p) => <option value={p}>{p}</option>)}
              </select>
            </div>
            <div>
              <label for="start-date" class="block text-sm font-medium text-diner-dark mb-1">How Soon Can You Start? *</label>
              <input type="text" id="start-date" name="start_date" required placeholder="e.g., Immediately, 2 weeks" class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-4 mt-4">
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Availability *</label>
              <div class="flex gap-4">
                {["Full Time", "Part Time", "Not Sure"].map((opt) => (
                  <label class="flex items-center gap-1.5 text-sm">
                    <input type="radio" name="availability" value={opt} required class="accent-diner-red" />
                    {opt}
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Reliable Transportation? *</label>
              <div class="flex gap-4">
                {["Yes", "No", "Certain Days"].map((opt) => (
                  <label class="flex items-center gap-1.5 text-sm">
                    <input type="radio" name="transportation" value={opt} required class="accent-diner-red" />
                    {opt}
                  </label>
                ))}
              </div>
            </div>
          </div>
          <div class="mt-4">
            <label class="block text-sm font-medium text-diner-dark mb-2">Available Days *</label>
            <div class="flex flex-wrap gap-3">
              {days.map((day) => (
                <label class="flex items-center gap-1.5 text-sm">
                  <input type="checkbox" name="available_days" value={day} class="accent-diner-red" />
                  {day}
                </label>
              ))}
            </div>
          </div>
        </fieldset>

        <!-- Experience -->
        <fieldset>
          <legend class="font-semibold text-diner-dark text-lg mb-4">Experience</legend>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Restaurant/Food Service Experience? *</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 text-sm">
                  <input type="radio" name="food_experience" value="Yes" required class="accent-diner-red" /> Yes
                </label>
                <label class="flex items-center gap-1.5 text-sm">
                  <input type="radio" name="food_experience" value="No" class="accent-diner-red" /> No
                </label>
              </div>
            </div>
            <div>
              <label for="education" class="block text-sm font-medium text-diner-dark mb-1">Highest Education *</label>
              <select id="education" name="education" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red">
                <option value="">Select</option>
                {educationLevels.map((lvl) => <option value={lvl}>{lvl}</option>)}
              </select>
            </div>
          </div>

          <!-- Previous Employers -->
          {[1, 2, 3].map((n) => (
            <div class="mt-4 p-4 bg-diner-cream rounded-lg">
              <p class="text-sm font-medium text-diner-gray mb-3">Previous Employer {n} {n === 1 ? "" : "(optional)"}</p>
              <div class="grid md:grid-cols-2 gap-3">
                <input type="text" name={`employer_${n}`} placeholder="Company name" class="rounded-lg border border-diner-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
                <input type="text" name={`position_${n}`} placeholder="Your position" class="rounded-lg border border-diner-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
                <input type="date" name={`start_${n}`} class="rounded-lg border border-diner-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
                <input type="date" name={`end_${n}`} class="rounded-lg border border-diner-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
              </div>
            </div>
          ))}

          <div class="mt-4">
            <label for="resume" class="block text-sm font-medium text-diner-dark mb-1">Resume (optional)</label>
            <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" class="w-full text-sm text-diner-gray file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-diner-red/10 file:text-diner-red hover:file:bg-diner-red/20" />
          </div>
        </fieldset>

        <!-- References -->
        <fieldset>
          <legend class="font-semibold text-diner-dark text-lg mb-4">References</legend>
          {[1, 2, 3].map((n) => (
            <div class="grid grid-cols-3 gap-3 mb-3">
              <input type="text" name={`ref_name_${n}`} placeholder={`Reference ${n} name`} required class="rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
              <input type="text" name={`ref_relation_${n}`} placeholder="Relation" required class="rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
              <input type="tel" name={`ref_phone_${n}`} placeholder="Phone" required class="rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          ))}
        </fieldset>

        <!-- Legal -->
        <fieldset>
          <legend class="font-semibold text-diner-dark text-lg mb-4">Eligibility</legend>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Legally authorized to work in the U.S.? *</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="us_authorized" value="Yes" required class="accent-diner-red" /> Yes</label>
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="us_authorized" value="No" class="accent-diner-red" /> No</label>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Are you 18 years of age or older? *</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="age_18" value="Yes" required class="accent-diner-red" /> Yes</label>
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="age_18" value="No" class="accent-diner-red" /> No</label>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-diner-dark mb-2">Have you been convicted of a felony? *</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="felony" value="Yes" required class="accent-diner-red" /> Yes</label>
                <label class="flex items-center gap-1.5 text-sm"><input type="radio" name="felony" value="No" class="accent-diner-red" /> No</label>
              </div>
            </div>
          </div>
        </fieldset>

        <!-- Why Join -->
        <div>
          <label for="why-join" class="block text-sm font-medium text-diner-dark mb-1">Why do you want to join our team? *</label>
          <textarea id="why-join" name="why_join" rows="4" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red resize-y"></textarea>
        </div>

        <!-- Consent & Submit -->
        <div class="space-y-4">
          <label class="flex items-start gap-2 text-sm text-diner-gray">
            <input type="checkbox" name="consent" required class="accent-diner-red mt-0.5" />
            <span>I certify that the information provided is accurate and authorize Johnny's Diner to contact me regarding this application.</span>
          </label>
          <button type="submit" class="w-full bg-diner-red text-white font-semibold py-3 rounded-full hover:bg-diner-red-dark transition-colors">
            Submit Application
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>
