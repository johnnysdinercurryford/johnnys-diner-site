---
import Layout from '../../layouts/Layout.astro';
import menuData from '../../data/menu.json';

const categories = menuData.categories;
---

<Layout title="Menu — Johnny's Diner">
  <!-- Hero -->
  <section class="bg-diner-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 text-center text-white">
      <h1 class="font-display text-4xl md:text-5xl mb-2 hero-animate hero-animate-1">Our Menu</h1>
      <p class="text-lg font-light hero-animate hero-animate-2">Classic homestyle cooking — made fresh every day</p>
      <button
        id="pdf-toggle-btn"
        class="inline-flex items-center gap-2 mt-6 bg-white text-diner-red font-bold text-sm md:text-base px-4 py-2.5 md:px-6 md:py-3 rounded-full shadow-md hover:bg-diner-cream transition-colors hero-animate hero-animate-3"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <span id="pdf-toggle-label">View Full Menu (PDF)</span>
        <svg id="pdf-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>
  </section>

  <!-- PDF Viewer -->
  <div id="pdf-viewer" class="hidden bg-diner-dark">
    <iframe src="/menu.pdf" class="w-full h-[80vh] border-0" title="Johnny's Diner Full Menu"></iframe>
  </div>

  <!-- Sticky Category Tabs -->
  <nav class="bg-white border-b border-diner-border sticky top-[78px] md:top-[96px] z-40 overflow-x-auto">
    <div class="max-w-6xl mx-auto px-4">
      <ul class="flex justify-center gap-1 py-2 whitespace-nowrap">
        {categories.map((cat) => (
          <li>
            <a
              href={`#${cat.id}`}
              data-tab={cat.id}
              class="menu-tab px-4 py-2 rounded-full text-sm font-medium text-diner-gray hover:text-diner-red hover:bg-diner-warm transition-colors"
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- All Categories -->
  <div class="max-w-6xl mx-auto px-4 py-12 space-y-20">
    {categories.map((cat, i) => (
      <section id={cat.id} class={`scroll-mt-40 rounded-2xl p-6 md:p-10 ${i % 2 === 0 ? 'bg-diner-red-light' : 'bg-diner-warm'}`}>
        <!-- Category Header -->
        <div class="mb-8 pb-4 border-b border-diner-border">
          <h2 class="font-display text-diner-red text-3xl">{cat.name}</h2>
          {cat.note && <p class="text-diner-gray mt-1">{cat.note}</p>}
        </div>

        <!-- Subcategories -->
        {cat.subcategories.map((sub) => (
          <div class="mb-6 bg-white rounded-2xl border border-diner-border shadow-sm overflow-hidden">
            <div class="bg-diner-red relative overflow-hidden px-6 py-4 text-center">
              <div class="absolute inset-0 opacity-10 stripe-bg"></div>
              <h3 class="relative text-white font-display text-xl">{sub.name}</h3>
              {sub.note && <p class="relative text-white/70 text-sm italic mt-1">{sub.note}</p>}
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {sub.items.map((item) => (
                <div class="bg-white rounded-xl border border-diner-border border-l-4 border-l-diner-red shadow-sm hover:shadow-md transition-shadow p-5">
                  <div class="flex justify-between items-start gap-3 mb-2">
                    <h4 class="font-semibold text-diner-dark leading-snug">{item.name}</h4>
                    <span class="shrink-0 bg-diner-red text-white text-xs font-bold px-2.5 py-1 rounded-full">${item.price.toFixed(2)}</span>
                  </div>
                  {item.description && <p class="text-sm text-diner-gray leading-relaxed">{item.description}</p>}
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}
  </div>

  <script>
    const pdfBtn = document.getElementById('pdf-toggle-btn');
    const pdfViewer = document.getElementById('pdf-viewer');
    const pdfLabel = document.getElementById('pdf-toggle-label');
    const pdfChevron = document.getElementById('pdf-chevron');

    pdfBtn?.addEventListener('click', () => {
      const isHidden = pdfViewer?.classList.contains('hidden');
      pdfViewer?.classList.toggle('hidden');
      if (pdfLabel) pdfLabel.textContent = isHidden ? 'Close Menu PDF' : 'View Full Menu (PDF)';
      pdfChevron?.classList.toggle('rotate-180', !!isHidden);
    });
  </script>

  <script>
    const tabs = document.querySelectorAll('.menu-tab');
    const sections = document.querySelectorAll('.max-w-6xl section[id]');

    const setActive = (id: string) => {
      tabs.forEach(tab => {
        const isActive = (tab as HTMLElement).dataset.tab === id;
        tab.classList.toggle('bg-diner-red', isActive);
        tab.classList.toggle('text-white', isActive);
        tab.classList.toggle('text-diner-gray', !isActive);
      });
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    }, { rootMargin: '-20% 0px -60% 0px', threshold: 0 });

    sections.forEach(s => observer.observe(s));
  </script>
</Layout>
