---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Johnny's Diner" description="Get in touch with Johnny's Diner on Curry Ford Road, Orlando FL. Call, email, or visit us.">
  <!-- Header -->
  <section class="bg-diner-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 text-center text-white">
      <h1 class="font-display text-4xl md:text-5xl mb-2 hero-animate hero-animate-1">Contact Us</h1>
      <p class="text-lg font-light hero-animate hero-animate-2">We'd love to hear from you</p>
    </div>
  </section>

  <!-- Info cards -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="menu-card p-6 text-center reveal">
        <div class="w-12 h-12 bg-diner-red-tint rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-diner-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <h3 class="font-semibold text-diner-dark mb-2">Phone</h3>
        <a href="tel:+14078688267" class="text-diner-red font-semibold hover:text-diner-red-dark transition-colors">(407) 868-8267</a>
      </div>
      <div class="menu-card p-6 text-center reveal">
        <div class="w-12 h-12 bg-diner-red-tint rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-diner-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-diner-dark mb-2">Address</h3>
        <p class="text-diner-gray text-sm">3335 Curry Ford Rd<br/>Orlando, FL 32806</p>
        <a href="https://maps.google.com/?q=3335+Curry+Ford+Rd+Orlando+FL+32806" target="_blank" rel="noopener" class="inline-block mt-3 text-diner-red text-sm font-semibold hover:text-diner-red-dark transition-colors">Get Directions &rarr;</a>
      </div>
      <div class="menu-card p-6 text-center reveal">
        <div class="w-12 h-12 bg-diner-red-tint rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-diner-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-diner-dark mb-2">Hours</h3>
        <p class="text-diner-gray text-sm">Mon &ndash; Sat: 6:00 AM &ndash; 3:00 PM<br/>Sunday: 7:00 AM &ndash; 3:00 PM</p>
        <p class="text-xs text-diner-gray/60 mt-2">Holiday hours may vary</p>
      </div>
    </div>

    <!-- Form + Map -->
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div class="menu-card p-8 reveal">
        <h2 class="font-display text-diner-red text-2xl mb-6">Send a Message</h2>
        <form action="https://formspree.io/f/maqproop" method="POST" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-first" class="block text-sm font-medium text-diner-dark mb-1">First Name</label>
              <input type="text" id="contact-first" name="first_name" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
            <div>
              <label for="contact-last" class="block text-sm font-medium text-diner-dark mb-1">Last Name</label>
              <input type="text" id="contact-last" name="last_name" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
            </div>
          </div>
          <div>
            <label for="contact-phone" class="block text-sm font-medium text-diner-dark mb-1">Phone</label>
            <input type="tel" id="contact-phone" name="phone" class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
          </div>
          <div>
            <label for="contact-email" class="block text-sm font-medium text-diner-dark mb-1">Email *</label>
            <input type="email" id="contact-email" name="email" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red" />
          </div>
          <div>
            <label for="contact-message" class="block text-sm font-medium text-diner-dark mb-1">Message *</label>
            <textarea id="contact-message" name="message" rows="5" required class="w-full rounded-lg border border-diner-border px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-diner-red/30 focus:border-diner-red resize-y"></textarea>
          </div>
          <label class="flex items-start gap-2 text-sm text-diner-gray">
            <input type="checkbox" name="consent" required class="accent-diner-red mt-0.5" />
            <span>I consent to being contacted by Johnny's Diner via phone, email, or text regarding my inquiry.</span>
          </label>
          <button type="submit" class="w-full bg-diner-red text-white font-semibold py-3 rounded-full hover:bg-diner-red-dark transition-colors">
            Send Message
          </button>
        </form>
      </div>

      <!-- Map -->
      <div class="reveal">
        <div class="rounded-2xl overflow-hidden shadow-lg h-full min-h-[400px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3507.5!2d-81.345!3d28.535!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88e77b5e5e5e5e5e%3A0x0!2s3335+Curry+Ford+Rd%2C+Orlando%2C+FL+32806!5e0!3m2!1sen!2sus!4v1"
            width="100%" height="100%" style="border:0; min-height:400px;" allowfullscreen loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Johnny's Diner location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
