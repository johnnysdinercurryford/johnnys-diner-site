---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reviews — Johnny's Diner" description="See what guests are saying about Johnny's Diner on Curry Ford Road, Orlando FL.">
  <!-- Header -->
  <section class="bg-diner-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-16 text-center text-white">
      <h1 class="font-display text-4xl md:text-5xl mb-2 hero-animate hero-animate-1">Guest Reviews</h1>
      <p class="text-lg font-light hero-animate hero-animate-2">Hear it straight from our community</p>
    </div>
  </section>

  <!-- Google Reviews Widget -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <script src="https://elfsightcdn.com/platform.js" async></script>
    <div class="elfsight-app-f3fee7f4-01da-43c4-9ad0-4e6302e1036a" data-elfsight-app-lazy></div>
  </section>

  <!-- Instagram Feed -->
  <section class="bg-diner-dark relative overflow-hidden py-16 md:py-20">
    <div class="absolute inset-0 opacity-10 stripe-bg"></div>
    <div class="relative max-w-5xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1 text-center md:text-left reveal">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
          </div>
          <h2 class="font-display text-white text-3xl md:text-4xl mb-3">We're on Instagram</h2>
          <p class="text-white/60 mb-2 text-lg">@johnnysdinercurryford</p>
          <p class="text-white/50 text-sm mb-8 leading-relaxed">Follow along for daily specials, behind-the-scenes, and a peek at what's cooking on the flat-top.</p>
          <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full transition-all duration-200" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
            Follow Us
          </a>
        </div>
        <div class="shrink-0 reveal">
          <div class="rounded-2xl overflow-hidden shadow-2xl" style="width:240px;">
            <script src="https://snapwidget.com/js/snapwidget.js"></script>
            <iframe src="https://snapwidget.com/embed/1120590" class="snapwidget-widget" allowtransparency="true" frameborder="0" scrolling="no" style="border:none; overflow:hidden; width:240px; height:240px;" title="Posts from Instagram"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
