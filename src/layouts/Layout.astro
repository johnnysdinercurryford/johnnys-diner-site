---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Johnny's Diner — Family owned & operated since 1995. Classic homestyle breakfast & lunch in Orlando, FL." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lobster&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-diner-border sticky top-0 z-50 stripe-bg-light">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/">
          <img src="/logo.png" alt="Johnny's Diner" class="h-14 md:h-20 w-auto" />
        </a>

        <!-- Mobile phone + badge (always visible) -->
        <div class="flex-1 flex md:hidden flex-col items-center gap-1">
          <a href="tel:+14078688267" class="flex items-center gap-1.5 bg-diner-red text-white font-semibold px-3 py-1.5 rounded-full text-xs">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            (407) 868-8267
          </a>
          <div id="mobile-header-badge"></div>
        </div>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-diner-dark hover:text-diner-red transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Desktop nav -->
        <ul class="hidden md:flex flex-1 items-center justify-center gap-2 text-base font-bold">
          <li><a href="/" class="px-4 py-1.5 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red hover:scale-125 transition-all duration-200">Home</a></li>
          <li class="relative group">
            <a href="/menu" class="inline-flex items-center gap-1 px-4 py-1.5 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red hover:scale-125 transition-all duration-200">
              Menu
              <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="hidden group-hover:block absolute top-full left-0 pt-2 z-50 min-w-[190px]">
              <div class="bg-white rounded-xl shadow-lg border border-diner-border py-1 text-sm font-medium">
                <a href="/menu#breakfast" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Breakfast</a>
                <a href="/menu#small-plates" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Small Plates &amp; Appetizers</a>
                <a href="/menu#handhelds" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Handhelds</a>
                <a href="/menu#dinners" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Dinners</a>
                <a href="/menu#kids" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Kids Menu</a>
                <a href="/menu#beverages" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Beverages</a>
              </div>
            </div>
          </li>
          <li class="relative group">
            <a href="/about" class="inline-flex items-center gap-1 px-4 py-1.5 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red hover:scale-125 transition-all duration-200">
              About Us
              <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="hidden group-hover:block absolute top-full left-0 pt-2 z-50 min-w-[190px]">
              <div class="bg-white rounded-xl shadow-lg border border-diner-border py-1 text-sm font-medium">
                <a href="/about#story" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Our Story</a>
                <a href="/about#awards" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">Awards &amp; Recognition</a>
                <a href="/about#press" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">In the Press</a>
                <a href="/about#values" class="block px-4 py-2 text-diner-dark hover:bg-diner-warm hover:text-diner-red transition-colors">What We Stand For</a>
              </div>
            </div>
          </li>
          <li><a href="/reviews" class="px-4 py-1.5 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red hover:scale-125 transition-all duration-200">Reviews</a></li>
          <li><a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full border border-[#FF3008]/40 bg-white shadow-sm text-[#FF3008] hover:bg-[#FF3008] hover:text-white hover:border-[#FF3008] hover:scale-125 transition-all duration-200">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm2.057 15.6H7.714V8.4h6.343c1.986 0 3.6 1.614 3.6 3.6s-1.614 3.6-3.6 3.6z"/></svg>
            DoorDash
          </a></li>
        </ul>
        <div class="hidden md:flex flex-col items-end gap-1">
          <a href="tel:+14078688267" class="flex items-center gap-2 bg-diner-red text-white font-semibold px-6 py-3 rounded-full hover:bg-diner-red-dark transition-colors text-base">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          (407) 868-8267
          </a>
          <div id="nav-hours-badge"></div>
        </div>
      </nav>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-diner-border">
        <ul class="flex flex-col px-4 py-3 gap-2 text-sm font-bold">
          <li><a href="/" class="block px-4 py-2 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red transition-all duration-200">Home</a></li>
          <li>
            <button class="mobile-submenu-btn w-full flex items-center justify-between px-4 py-2 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red transition-all duration-200" data-target="mobile-menu-submenu">
              <span>Menu</span>
              <svg class="mobile-submenu-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul id="mobile-menu-submenu" class="hidden mt-1 ml-4 flex flex-col gap-1">
              <li><a href="/menu#breakfast" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Breakfast</a></li>
              <li><a href="/menu#small-plates" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Small Plates &amp; Appetizers</a></li>
              <li><a href="/menu#handhelds" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Handhelds</a></li>
              <li><a href="/menu#dinners" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Dinners</a></li>
              <li><a href="/menu#kids" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Kids Menu</a></li>
              <li><a href="/menu#beverages" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Beverages</a></li>
            </ul>
          </li>
          <li>
            <button class="mobile-submenu-btn w-full flex items-center justify-between px-4 py-2 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red transition-all duration-200" data-target="mobile-about-submenu">
              <span>About Us</span>
              <svg class="mobile-submenu-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <ul id="mobile-about-submenu" class="hidden mt-1 ml-4 flex flex-col gap-1">
              <li><a href="/about#story" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Our Story</a></li>
              <li><a href="/about#awards" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">Awards &amp; Recognition</a></li>
              <li><a href="/about#press" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">In the Press</a></li>
              <li><a href="/about#values" class="block px-4 py-1.5 rounded-full text-sm text-diner-dark border border-diner-border bg-white hover:bg-diner-warm hover:text-diner-red transition-colors">What We Stand For</a></li>
            </ul>
          </li>
          <li><a href="/reviews" class="block px-4 py-2 rounded-full border border-diner-border bg-white shadow-sm hover:bg-diner-red hover:text-white hover:border-diner-red transition-all duration-200">Reviews</a></li>
          <li><a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-[#FF3008]/40 bg-white shadow-sm text-[#FF3008] hover:bg-[#FF3008] hover:text-white hover:border-[#FF3008] transition-all duration-200">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm2.057 15.6H7.714V8.4h6.343c1.986 0 3.6 1.614 3.6 3.6s-1.614 3.6-3.6 3.6z"/></svg>
            DoorDash
          </a></li>
          <li>
            <a href="tel:+14078688267" class="flex items-center gap-2 bg-diner-red text-white font-semibold px-4 py-2.5 rounded-full w-fit hover:bg-diner-red-dark transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              (407) 868-8267
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-diner-dark text-white/80">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <div class="inline-block bg-white rounded-full p-2 mb-3">
              <img src="/logo.png" alt="Johnny's Diner" class="h-16 w-auto" />
            </div>
            <p class="text-sm leading-relaxed">Family owned & operated since 1995.<br/>Classic homestyle breakfast & lunch in Orlando, FL.</p>
            <a href="https://curryfordwest.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 mt-4 bg-diner-red-dark border-2 border-white/40 rounded-xl px-4 py-3 hover:bg-diner-red transition-colors">
              <img src="/curryfordwest-logo.png" alt="Curry Ford West" class="h-10 w-auto shrink-0" />
              <span class="text-white font-semibold text-sm"><strong>Proud Member</strong> &ndash; Curry Ford West</span>
            </a>
          </div>

          <!-- Hours & Location -->
          <div>
            <h4 class="font-semibold text-white mb-3">Hours & Location</h4>
            <p class="text-sm leading-relaxed">
              Mon &ndash; Sat: 6:00 AM &ndash; 3:00 PM<br/>
              Sunday: 7:00 AM &ndash; 3:00 PM<br/>
              <span class="text-white/60 text-xs">Holiday hours may vary. Please call ahead.</span>
            </p>
            <p class="text-sm mt-3">
              3335 Curry Ford Rd<br/>
              Orlando, FL 32806
            </p>
          </div>

          <!-- Contact & Social -->
          <div>
            <h4 class="font-semibold text-white mb-3">Get In Touch</h4>
            <p class="text-sm">
              <a href="tel:+14078688267" class="hover:text-white transition-colors">(407) 868-8267</a>
            </p>
            <p class="text-sm mt-2">
              <span class="text-white/40">Contact &mdash;</span> <a href="/contact" class="hover:text-white transition-colors">Get In Touch &rarr;</a>
            </p>
            <p class="text-sm mt-2">
              <span class="text-white/40">Careers &mdash;</span> <a href="/careers" class="hover:text-white transition-colors">Join Our Team &rarr;</a>
            </p>
            <a href="https://www.doordash.com/store/johnny's-diner-curry-ford-orlando-37556239/85104946/?&pickup=false" target="_blank" rel="noopener noreferrer" class="inline-block mt-3 bg-[#FF3008] text-white text-sm font-semibold px-4 py-2 rounded-full hover:bg-[#e02a07] transition-colors">
              Order on DoorDash
            </a>
            <div class="flex gap-4 mt-4">
              <a href="https://www.facebook.com/profile.php?id=61576530234741" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="border-t border-white/10 mt-8 pt-6 text-center text-xs text-white/40">
          &copy; {new Date().getFullYear()} Johnny's Diner. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      document.querySelectorAll('.mobile-submenu-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const targetId = (btn as HTMLElement).dataset.target;
          const submenu = document.getElementById(targetId!);
          const chevron = btn.querySelector('.mobile-submenu-chevron');
          const isHidden = submenu?.classList.contains('hidden');
          submenu?.classList.toggle('hidden');
          chevron?.classList.toggle('rotate-180', !!isHidden);
        });
      });

      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const icon = document.getElementById('menu-icon');

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        if (isOpen) {
          icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        } else {
          icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        }
      });

      // Open/Closed badge
      const now = new Date();
      const day = now.getDay(); // 0=Sun, 1=Mon...6=Sat
      const hour = now.getHours() + now.getMinutes() / 60;
      const openHour = day === 0 ? 7 : 6; // Sun opens at 7am, all others 6am
      const isOpen = hour >= openHour && hour < 15;

      let badgeHTML;
      if (isOpen) {
        badgeHTML = '<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-green-600 text-white shadow-sm"><span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>Open until 3pm</span>';
      } else {
        let nextOpenLabel;
        if (hour < openHour) {
          nextOpenLabel = 'today at ' + (openHour === 7 ? '7am' : '6am');
        } else {
          const tomorrowDay = (day + 1) % 7;
          const tomorrowOpen = tomorrowDay === 0 ? '7am' : '6am';
          nextOpenLabel = 'tomorrow at ' + tomorrowOpen;
        }
        badgeHTML = '<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-diner-dark text-white shadow-sm"><span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>Closed \u00b7 Opens ' + nextOpenLabel + '</span>';
      }

      const navBadge = document.getElementById('nav-hours-badge');
      if (navBadge) navBadge.innerHTML = badgeHTML;

      const mobileHeaderBadge = document.getElementById('mobile-header-badge');
      if (mobileHeaderBadge) mobileHeaderBadge.innerHTML = badgeHTML;

      // Scroll reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal, .slide-left, .slide-right').forEach((el) => observer.observe(el));

      // Carousel — infinite loop
      const carousel = document.getElementById('carousel');
      const prevBtn = document.getElementById('carousel-prev');
      const nextBtn = document.getElementById('carousel-next');
      if (carousel) {
        // Clone all items and append for infinite effect
        const items = Array.from(carousel.children);
        items.forEach(item => carousel.appendChild(item.cloneNode(true)));

        const scrollAmt = () => (carousel.querySelector('div')?.offsetWidth || 300) + 16;

        prevBtn?.addEventListener('click', () => {
          const half = carousel.scrollWidth / 2;
          if (carousel.scrollLeft - scrollAmt() <= 0) carousel.scrollLeft += half;
          carousel.scrollBy({ left: -scrollAmt(), behavior: 'smooth' });
        });
        nextBtn?.addEventListener('click', () => {
          const half = carousel.scrollWidth / 2;
          if (carousel.scrollLeft + scrollAmt() >= half) carousel.scrollLeft -= half;
          carousel.scrollBy({ left: scrollAmt(), behavior: 'smooth' });
        });

        // Auto-scroll: silently reset position before scrolling, never use scroll event
        setInterval(() => {
          const half = carousel.scrollWidth / 2;
          if (carousel.scrollLeft >= half) carousel.scrollLeft -= half;
          carousel.scrollBy({ left: scrollAmt(), behavior: 'smooth' });
        }, 3000);
      }
    </script>
  </body>
</html>
