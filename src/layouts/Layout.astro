              <span class="text-white font-semibold text-sm"><strong>Proud Member</strong> &ndash; Curry Ford West</span>
            </a>
          </div>

          <!-- Hours & Location -->
          <div>
            <h4 class="font-semibold text-white mb-3">Hours & Location</h4>
