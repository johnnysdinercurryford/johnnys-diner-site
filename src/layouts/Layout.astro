---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Johnny's Diner — Family owned & operated since 1995. Classic homestyle breakfast & lunch in Orlando, FL." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lobster&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-diner-border sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/">
          <img src="/logo.png" alt="Johnny's Diner" class="h-24 md:h-32 w-auto" />
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-diner-dark hover:text-diner-red transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-6 text-sm font-medium">
          <li><a href="/" class="hover:text-diner-red transition-colors">Home</a></li>
          <li><a href="/menu" class="hover:text-diner-red transition-colors">Menu</a></li>
          <li><a href="/about" class="hover:text-diner-red transition-colors">About</a></li>
          <li><a href="/careers" class="hover:text-diner-red transition-colors">Careers</a></li>
          <li><a href="/contact" class="hover:text-diner-red transition-colors">Contact</a></li>
        </ul>
      </nav>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-diner-border">
        <ul class="flex flex-col px-4 py-3 gap-3 text-sm font-medium">
          <li><a href="/" class="block py-2 hover:text-diner-red transition-colors">Home</a></li>
          <li><a href="/menu" class="block py-2 hover:text-diner-red transition-colors">Menu</a></li>
          <li><a href="/about" class="block py-2 hover:text-diner-red transition-colors">About</a></li>
          <li><a href="/careers" class="block py-2 hover:text-diner-red transition-colors">Careers</a></li>
          <li><a href="/contact" class="block py-2 hover:text-diner-red transition-colors">Contact</a></li>
        </ul>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-diner-dark text-white/80">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <h3 class="font-display text-white text-2xl mb-3">Johnny's Diner</h3>
            <p class="text-sm leading-relaxed">Family owned & operated since 1995.<br/>Classic homestyle breakfast & lunch in Orlando, FL.</p>
          </div>

          <!-- Hours & Location -->
          <div>
            <h4 class="font-semibold text-white mb-3">Hours & Location</h4>
            <p class="text-sm leading-relaxed">
              Mon &ndash; Sat: 6:00 AM &ndash; 3:00 PM<br/>
              Sunday: 7:00 AM &ndash; 3:00 PM<br/>
              <span class="text-white/60 text-xs">Holiday hours may vary. Please call ahead.</span>
            </p>
            <p class="text-sm mt-3">
              3335 Curry Ford Rd<br/>
              Orlando, FL 32806
            </p>
          </div>

          <!-- Contact & Social -->
          <div>
            <h4 class="font-semibold text-white mb-3">Get In Touch</h4>
            <p class="text-sm">
              <a href="tel:+14078688267" class="hover:text-white transition-colors">(407) 868-8267</a>
            </p>
            <div class="flex gap-4 mt-4">
              <a href="#" aria-label="Facebook" class="hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/johnnysdinercurryford" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="border-t border-white/10 mt-8 pt-6 text-center text-xs text-white/40">
          &copy; {new Date().getFullYear()} Johnny's Diner. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const icon = document.getElementById('menu-icon');

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden');
        if (isOpen) {
          icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        } else {
          icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        }
      });
    </script>
  </body>
</html>
