              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.071 8.409a6.09 6.09 0 00-5.396-3.228H.584A.589.589 0 00.17 6.184L3.894 9.93a1.752 1.752 0 001.242.516h12.049a1.554 1.554 0 11.031 3.108H8.91a.589.589 0 00-.415 1.003l3.725 3.747a1.75 1.75 0 001.242.516h3.757c4.887 0 8.584-5.225 5.852-10.413"/></svg>
              DoorDash
            </a></li>
          </ul>
        </div>

        <!-- Desktop phone + badge -->
        <div class="hidden md:flex flex-col items-end gap-1">
          <a href="tel:+14078688267" class="flex items-center gap-2 bg-diner-red text-white font-semibold px-6 py-3 rounded-full hover:bg-diner-red-dark transition-colors text-base">
